{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build SASS",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build-sass:dev"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Build Library",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build-lib:dev"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Start Showcase",
      "type": "shell",
      "command": "npm",
      "args": [
        "start",
        "--",
        "--open"
      ],
      "problemMatcher": [],
      // We need to give the other tasks time to compile before trying to start
      // So delay by a few seconds
      "dependsOn": ["delay 5 seconds"],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "delay 5 seconds",
      "type": "shell",
      "command": "sleep",
      "args": [
        "5s"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Start All",
      "dependsOn": [
        "Build SASS",
        "Build Library",
        "Start Showcase"
      ],
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
